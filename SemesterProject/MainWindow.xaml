<Window x:Class="SemesterProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SemesterProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left side menu -->
        <StackPanel Grid.Column="0" Margin="10" Background="LightGray">

            <TextBlock Text="Household Manager"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="10"
                   TextAlignment="Center"/>

            <Button Content="Fridge Contents"
                Height="45"
                Margin="10"
                FontSize="16"/>

            <Button Content="Add Food"
                Height="45"
                Margin="10"
                FontSize="16"/>

            <Button Content="Remove Food"
                Height="45"
                Margin="10"
                FontSize="16"/>

            <Button Content="Household Members"
                Height="45"
                Margin="10"
                FontSize="16"/>

        </StackPanel>

        <!-- Right side content area -->
        <Grid Grid.Column="1" Margin="10">
            <TextBlock Text="Choose a menu option!"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
