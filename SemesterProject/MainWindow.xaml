<Window x:Class="SemesterProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SemesterProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="502" Width="927">
    <Grid Background="#F4F1EA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="67.308"/>
            <ColumnDefinition Width="182.692"/>
            <ColumnDefinition Width="54*"/>
            <ColumnDefinition Width="621*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Left side menu -->
        <Border Grid.Column="0"
            Background="#2F3E34" Grid.ColumnSpan="2">
            <StackPanel Margin="15">

                <TextBlock Text="Household&#x0a;Manager"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,25,0,35"
                       TextAlignment="Center"/>

                <Button Content="Fridge Contents"
                    Height="50"
                    Margin="0,8"
                    FontSize="16"
                    Background="#A7C957"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="FridgeContentsButton_Click"/>

                <Button Content="Household Members"
                    Height="50"
                    Margin="0,8"
                    FontSize="16"
                    Background="#386641"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="HouseholdMembersButton_Click"/>

            </StackPanel>
        </Border>

        <!-- Right side content -->
        <Grid Grid.Column="2" Margin="30,30,28,30" Grid.ColumnSpan="2">
            <Border Background="White"
                CornerRadius="18"
                Padding="30"
                BorderBrush="#DAD7CD"
                BorderThickness="1">

                <Grid>

                    <!-- Main page -->
                    <StackPanel x:Name="MainPagePanel"
                            Visibility="Visible"
                            VerticalAlignment="Center">

                        <TextBlock Text="Welcome to your Household Manager"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,15"/>

                        <TextBlock Text="Manage your fridge contents and household members in one simple application."
                               FontSize="17"
                               Foreground="#555555"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                        <Border Background="#FFF3CD"
                            CornerRadius="10"
                            Padding="18"
                            Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Favorite food alerts"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#7A4F01"
                                       TextAlignment="Center"
                                       Margin="0,0,0,10"/>

                                <TextBlock Text="{Binding AlertMessage}"
                                       FontSize="16"
                                       Foreground="#7A4F01"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Choose Fridge Contents or Household Members from the left menu."
                               FontSize="18"
                               Foreground="#386641"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Fridge page -->
                    <StackPanel x:Name="FridgePagePanel"
                            Visibility="Collapsed">

                        <Button Content="Back to Main Page"
                            Width="160"
                            Height="35"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15"
                            Background="#DDA15E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BackToMainPageButton_Click"/>

                        <TextBlock Text="Fridge Contents"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                        <ListBox ItemsSource="{Binding FridgeFoods}"
                             FontSize="16"
                             MinHeight="180"
                             Margin="0,0,0,20"
                             BorderBrush="#DAD7CD"
                             BorderThickness="1"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Add food box -->
                            <Border Grid.Column="0"
                                Background="#F4F1EA"
                                CornerRadius="12"
                                Padding="15"
                                Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Add Food"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#386641"
                                           Margin="0,0,0,10"/>

                                    <TextBox x:Name="FoodNameTextBox"
                                         Height="35"
                                         Margin="0,5"
                                         FontSize="15"
                                         Text="Food name"/>

                                    <TextBox x:Name="FoodQuantityTextBox"
                                         Height="35"
                                         Margin="0,5"
                                         FontSize="15"
                                         Text="Quantity"/>

                                    <Button Content="Add Food"
                                        Height="40"
                                        Margin="0,10,0,0"
                                        Background="#6A994E"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Click="AddFoodButton_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Remove food box -->
                            <Border Grid.Column="1"
                                Background="#F4F1EA"
                                CornerRadius="12"
                                Padding="15"
                                Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Remove Food"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#BC4749"
                                           Margin="0,0,0,10"/>

                                    <TextBox x:Name="RemoveFoodNameTextBox"
                                         Height="35"
                                         Margin="0,5"
                                         FontSize="15"
                                         Text="Food name"/>

                                    <TextBox x:Name="RemoveFoodQuantityTextBox"
                                         Height="35"
                                         Margin="0,5"
                                         FontSize="15"
                                         Text="Quantity"/>

                                    <Button Content="Remove Food"
                                        Height="40"
                                        Margin="0,10,0,0"
                                        Background="#BC4749"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Click="RemoveFoodButton_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Members page -->
                    <StackPanel x:Name="MembersPagePanel"
                            Visibility="Collapsed">

                        <Button Content="Back to Main Page"
                            Width="160"
                            Height="35"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15"
                            Background="#DDA15E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BackToMainPageButton_Click"/>

                        <TextBlock Text="Household Members"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                        <ListBox ItemsSource="{Binding HouseholdMembers}"
                             FontSize="16"
                             MinHeight="180"
                             Margin="0,0,0,20"
                             BorderBrush="#DAD7CD"
                             BorderThickness="1"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Add member box -->
                            <Border Grid.Column="0"
                                Background="#F4F1EA"
                                CornerRadius="12"
                                Padding="15"
                                Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Add Member"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#386641"
                                           Margin="0,0,0,10"/>

                                    <TextBox x:Name="MemberNameTextBox"
                                         Height="35"
                                         Margin="0,5"
                                         FontSize="15"
                                         Text="Member name"/>

                                    <TextBox x:Name="FavoriteFoodTextBox"
                                         Height="35"
                                         Margin="0,5"
                                         FontSize="15"
                                         Text="Favorite food"/>

                                    <Button Content="Add Member"
                                        Height="40"
                                        Margin="0,10,0,0"
                                        Background="#588157"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Click="AddMemberButton_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Remove member box -->
                            <Border Grid.Column="1"
                                Background="#F4F1EA"
                                CornerRadius="12"
                                Padding="15"
                                Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Remove Member"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#9B2226"
                                           Margin="0,0,0,10"/>

                                    <TextBox x:Name="RemoveMemberNameTextBox"
                                         Height="35"
                                         Margin="0,5"
                                         FontSize="15"
                                         Text="Member name"/>

                                    <Button Content="Remove Member"
                                        Height="40"
                                        Margin="0,10,0,0"
                                        Background="#9B2226"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Click="RemoveMemberButton_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
