<Window x:Class="SemesterProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SemesterProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="502" Width="927">
    <Grid Background="#F4F1EA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left side menu -->
        <Border Grid.Column="0"
            Background="#2F3E34">
            <StackPanel Margin="15">

                <TextBlock Text="Household&#x0a;Manager"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,25,0,35"
                       TextAlignment="Center"/>

                <Button Content="Fridge Contents"
                    Height="48"
                    Margin="0,7"
                    FontSize="15"
                    Background="#A7C957"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="FridgeContentsButton_Click"/>

                <Button Content="Add Food"
                    Height="48"
                    Margin="0,7"
                    FontSize="15"
                    Background="#6A994E"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="ShowAddFoodButton_Click"/>

                <Button Content="Remove Food"
                    Height="48"
                    Margin="0,7"
                    FontSize="15"
                    Background="#BC4749"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="ShowRemoveFoodButton_Click"/>

                <Button Content="Add Member"
                    Height="48"
                    Margin="0,7"
                    FontSize="15"
                    Background="#588157"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="ShowAddMemberButton_Click"/>

                <Button Content="Remove Member"
                    Height="48"
                    Margin="0,7"
                    FontSize="15"
                    Background="#9B2226"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="ShowRemoveMemberButton_Click"/>

            </StackPanel>
        </Border>

        <!-- Right side page area -->
        <Grid Grid.Column="1" Margin="30">

            <Border Background="White"
                CornerRadius="18"
                Padding="30"
                BorderBrush="#DAD7CD"
                BorderThickness="1">

                <Grid>

                    <!-- Main page -->
                    <StackPanel x:Name="MainPagePanel"
                            Visibility="Visible"
                            VerticalAlignment="Center">

                        <TextBlock Text="Welcome to your Household Manager"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,15"/>

                        <TextBlock Text="This application helps you manage fridge contents, food stock and household members."
                               FontSize="17"
                               Foreground="#555555"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                        <Border Background="#FFF3CD"
                            CornerRadius="10"
                            Padding="18"
                            Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Favorite food alerts"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#7A4F01"
                                       TextAlignment="Center"
                                       Margin="0,0,0,10"/>

                                <TextBlock x:Name="AlertTextBlock"
                                       Text="{Binding AlertMessage}"
                                       FontSize="16"
                                       Foreground="#7A4F01"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Choose an option from the left menu."
                               FontSize="18"
                               Foreground="#386641"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>

                    </StackPanel>

                    <!-- Fridge contents page -->
                    <StackPanel x:Name="FridgePagePanel"
                            Visibility="Collapsed">

                        <Button Content="Back to Main Page"
                            Width="150"
                            Height="35"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15"
                            Background="#DDA15E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BackToMainPageButton_Click"/>

                        <TextBlock Text="Fridge Contents"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                        <ListBox x:Name="FridgeListBox"
                             ItemsSource="{Binding FridgeFoods}"
                             FontSize="16"
                             MinHeight="250"
                             BorderBrush="#DAD7CD"
                             BorderThickness="1"/>
                    </StackPanel>

                    <!-- Add food page -->
                    <StackPanel x:Name="AddFoodPagePanel"
                            Visibility="Collapsed">

                        <Button Content="Back to Main Page"
                            Width="150"
                            Height="35"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15"
                            Background="#DDA15E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BackToMainPageButton_Click"/>

                        <TextBlock Text="Add Food"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                        <TextBox x:Name="FoodNameTextBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="15"
                             Text="Food name"/>

                        <TextBox x:Name="FoodQuantityTextBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="15"
                             Text="Quantity"/>

                        <Button Content="Add Food"
                            Height="40"
                            Margin="0,10"
                            Background="#6A994E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="AddFoodButton_Click"/>
                    </StackPanel>

                    <!-- Remove food page -->
                    <StackPanel x:Name="RemoveFoodPagePanel"
                            Visibility="Collapsed">

                        <Button Content="Back to Main Page"
                            Width="150"
                            Height="35"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15"
                            Background="#DDA15E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BackToMainPageButton_Click"/>

                        <TextBlock Text="Remove Food"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                        <TextBox x:Name="RemoveFoodNameTextBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="15"
                             Text="Food name"/>

                        <TextBox x:Name="RemoveFoodQuantityTextBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="15"
                             Text="Quantity"/>

                        <Button Content="Remove Food"
                            Height="40"
                            Margin="0,10"
                            Background="#BC4749"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="RemoveFoodButton_Click"/>
                    </StackPanel>

                    <!-- Add member page -->
                    <StackPanel x:Name="AddMemberPagePanel"
                            Visibility="Collapsed">

                        <Button Content="Back to Main Page"
                            Width="150"
                            Height="35"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15"
                            Background="#DDA15E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BackToMainPageButton_Click"/>

                        <TextBlock Text="Add Member"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                        <TextBox x:Name="MemberNameTextBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="15"
                             Text="Member name"/>

                        <TextBox x:Name="FavoriteFoodTextBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="15"
                             Text="Favorite food"/>

                        <Button Content="Add Member"
                            Height="40"
                            Margin="0,10"
                            Background="#588157"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="AddMemberButton_Click"/>
                    </StackPanel>

                    <!-- Remove member page -->
                    <StackPanel x:Name="RemoveMemberPagePanel"
                            Visibility="Collapsed">

                        <Button Content="Back to Main Page"
                            Width="150"
                            Height="35"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15"
                            Background="#DDA15E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BackToMainPageButton_Click"/>

                        <TextBlock Text="Remove Member"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2F3E34"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                        <TextBox x:Name="RemoveMemberNameTextBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="15"
                             Text="Member name"/>

                        <Button Content="Remove Member"
                            Height="40"
                            Margin="0,10"
                            Background="#9B2226"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="RemoveMemberButton_Click"/>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
    
</Window>
