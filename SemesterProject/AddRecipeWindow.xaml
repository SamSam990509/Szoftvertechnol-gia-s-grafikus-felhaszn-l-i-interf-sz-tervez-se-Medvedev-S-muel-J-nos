<Window x:Class="SemesterProject.AddRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Recipe"
        Height="500"
        Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#F4F1EA" Margin="20">
        <Border Background="White"
                CornerRadius="15"
                Padding="20"
                BorderBrush="#DAD7CD"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="Add New Recipe"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2F3E34"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Recipe name"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#386641"/>

                <TextBox x:Name="RecipeNameTextBox"
                         Height="35"
                         FontSize="15"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Add ingredient"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#386641"
                           Margin="0,0,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="IngredientNameTextBox"
                             Grid.Column="0"
                             Height="35"
                             FontSize="15"
                             Margin="0,0,10,0"
                             Text="Ingredient name"/>

                    <TextBox x:Name="IngredientQuantityTextBox"
                             Grid.Column="1"
                             Height="35"
                             FontSize="15"
                             Text="Quantity"/>
                </Grid>

                <Button Content="Add / Modify Ingredient"
                        Height="38"
                        Margin="0,10,0,10"
                        Background="#588157"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="AddIngredientButton_Click"/>

                <Button Content="Remove Selected Ingredient"
                        Height="38"
                        Margin="0,0,0,10"
                        Background="#9B2226"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="RemoveIngredientButton_Click"/>

                <TextBlock Text="Ingredients"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#2F3E34"
                           Margin="0,0,0,5"/>

                <ListBox x:Name="IngredientsListBox"
                         Height="120"
                         FontSize="15"
                         BorderBrush="#DAD7CD"
                         BorderThickness="1"
                         Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="Save"
                            Grid.Column="0"
                            Height="40"
                            Margin="0,0,10,0"
                            Background="#6A994E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="SaveButton_Click"/>

                    <Button Content="Cancel"
                            Grid.Column="1"
                            Height="40"
                            Margin="10,0,0,0"
                            Background="#BC4749"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="CancelButton_Click"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>